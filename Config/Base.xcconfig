// Config/Base.xcconfig — committed defaults.
// Do NOT put secrets here. Override keys in Config/Secrets.xcconfig (gitignored),
// which is generated by scripts/secrets-sync.sh from .env.

SUPABASE_URL = https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY = REPLACE_ME
GEMINI_PROXY_URL = https://YOUR-PROJECT.supabase.co/functions/v1/ai-gateway

// Info.plist reads: ${SUPABASE_URL}, ${SUPABASE_ANON_KEY}, ${GEMINI_PROXY_URL}

#include? "Secrets.xcconfig"
