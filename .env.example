# Ladder local dev env — copy to .env and fill in. NEVER commit the .env.
# Client-only values (anon key, project URL) are read into Info.plist via
# Config/Secrets.xcconfig by scripts/secrets-sync.sh. Server-only values
# (service role, Gemini key, AWS creds) are consumed by Edge Functions
# and the seed scripts.

# ---- iOS app (public) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
GEMINI_PROXY_URL=https://YOUR-PROJECT.supabase.co/functions/v1/ai-gateway

# ---- Edge Functions (secret) ----
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ---- AWS KMS (secret) ----
AWS_REGION=us-east-1
LADDER_KMS_CMK_ID=arn:aws:kms:us-east-1:000000000000:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Dev convenience ----
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres
